# VHF – clear Audio replay: Konfiguration
# Kopieren nach  /etc/vhf/vhf.conf  (wird ohne Neustart gelesen).
# Format: key = value ; Zeilen mit # sind Kommentare.

# Schiffsname in den Titelzeilen von Panel (:8090) und Nachhör-Liste.
#   auto        = aus Signal K holen (vessels.self.name), sonst Fallback "Wilhelmina"
#   <Name>      = fester Name (überschreibt Signal K)
shipname = auto

# Signal-K-Server für den Schiffsnamen (nur bei shipname = auto).
signalk = http://localhost:3000

# HomePod-/AirPlay-Übernahme im Panel (:8090) — nur relevant mit Control-Panel-Add-on:
#   auto = zeigen, wenn HomePods (ShiPod-Ausgänge) in OwnTone erkannt werden
#   on   = immer zeigen
#   off  = nie zeigen — Panel nutzt nur den Messe-Lautsprecher
homepods = auto
